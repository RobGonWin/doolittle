# Core runtime
DOOLITTLE_NAME=Doolittle
DOOLITTLE_MODE=both
DOOLITTLE_PORT=3000
# Local-first default. The loopback bind is restricted to this machine by the OS.
# To expose the API on a LAN/public interface (e.g. 0.0.0.0), you MUST also set
# DOOLITTLE_API_TOKEN — non-loopback binds reject every request without it.
DOOLITTLE_HOST=127.0.0.1
# DOOLITTLE_API_TOKEN=change-me-to-a-long-random-secret
DOOLITTLE_DATA_DIR=.doolittle
DOOLITTLE_SKILLS_DIR=./packages/skills
DOOLITTLE_TIMEZONE=America/Chicago
DOOLITTLE_GATEWAY_DATA_DIR=.doolittle/gateway
DOOLITTLE_HOOKS_DIR=.doolittle/hooks
DOOLITTLE_WORKSPACE_DIR=.
DOOLITTLE_ALLOW_ALL_USERS=false
DOOLITTLE_PAIRING_MODE=pair

# Default model inference through the signed-in local Devin CLI.
DOOLITTLE_USE_LINKED_DEVIN_AUTH=true
DEVIN_CLI_COMMAND=devin
DEVIN_MODEL=swe-1-6-fast
DEVIN_TIMEOUT_MS=120000

# Local embeddings through the official ElizaOS Ollama plugin.
# Make sure Ollama is running, then pull the configured embedding model.
OLLAMA_API_ENDPOINT=http://localhost:11434/api
OLLAMA_SMALL_MODEL=granite4.1:3b
OLLAMA_LARGE_MODEL=granite4.1:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
DOOLITTLE_EMBEDDING_PROVIDER=local

# Optional Eliza Cloud managed inference settings.
ELIZAOS_CLOUD_ENABLED=false
ELIZAOS_CLOUD_API_KEY=
ELIZAOS_CLOUD_BASE_URL=https://www.elizacloud.ai/api/v1
ELIZAOS_CLOUD_SMALL_MODEL=xai/grok-4.1-fast-non-reasoning
ELIZAOS_CLOUD_LARGE_MODEL=xai/grok-4.1-fast-reasoning
ELIZAOS_CLOUD_EMBEDDING_MODEL=openai/text-embedding-3-small
# ELIZAOS_CLOUD_EMBEDDING_URL=https://www.elizacloud.ai/api/v1
# ELIZAOS_CLOUD_EMBEDDING_API_KEY=
# ELIZAOS_CLOUD_EMBEDDING_DIMENSIONS=1536

# Official OpenAI plugin settings.
# Leave unset if you want the local Ollama path or plan to use Anthropic instead.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_IMAGE_MODEL=
OPENAI_TEMPERATURE=0.4
OPENAI_MAX_TOKENS=1200

# Official Anthropic plugin settings.
# Set these if you want Claude-backed execution through the ElizaOS Anthropic plugin.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_SETUP_TOKEN=
DOOLITTLE_CLAUDE_CODE_CLI_FALLBACK=false
ANTHROPIC_BASE_URL=
ANTHROPIC_SMALL_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_LARGE_MODEL=claude-sonnet-4.6

# Official autocoder / E2B ecosystem settings.
# E2B defaults to local mode at runtime unless you override it here.
E2B_MODE=local
E2B_API_KEY=
E2B_BASE_URL=
GITHUB_TOKEN=

# Roblox Open Cloud governance.
#
# Create a dedicated API key for one documented purpose. Do not use a personal
# account's unrestricted key, .ROBLOSECURITY cookie, or a key covering every
# group resource. Restrict the key to the required experience, operations,
# expiration period, and source IPs where Roblox supports those controls.
#
# Every value ending in API_KEY is secret. Never place more than one credential
# in a variable or commit a populated value. This is the canonical RTF key for
# 1v1-edit-arena-prod-governance-readonly.
ROBLOX_PROD_GOVERNANCE_API_KEY=
# Backwards-compatible alias for existing integrations. If populated, use the
# same value as ROBLOX_PROD_GOVERNANCE_API_KEY. Doolittle prefers the canonical
# variable and falls back to this alias. Do not rely on dotenv variable expansion.
ROBLOX_OPEN_CLOUD_API_KEY=
ROBLOX_STAGING_PLACE_PUBLISHER_API_KEY=
ROBLOX_STAGING_COMMERCE_API_KEY=
ROBLOX_PROD_COMMERCE_READ_API_KEY=
ROBLOX_PROD_COMMERCE_WRITE_API_KEY=
ROBLOX_GROUP_ASSET_PUBLISHER_API_KEY=

# Provisioned credentials stay dormant until their private worker is ready.
# Enabling a lane does not bypass scopes, dry-run, capability, or approval gates.
ROBLOX_PROD_GOVERNANCE_ENABLED=false
ROBLOX_STAGING_PLACE_PUBLISHER_ENABLED=false
ROBLOX_STAGING_COMMERCE_ENABLED=false
ROBLOX_PROD_COMMERCE_READ_ENABLED=false
ROBLOX_PROD_COMMERCE_WRITE_ENABLED=false
ROBLOX_GROUP_ASSET_PUBLISHER_ENABLED=false

ROBLOX_OPEN_CLOUD_KEY_LABEL=1v1-edit-arena-governance-readonly
ROBLOX_OPEN_CLOUD_PURPOSE=Read-only governance evidence collection
ROBLOX_OPEN_CLOUD_OWNER_TYPE=dedicated-group-automation-account
ROBLOX_OPEN_CLOUD_ROTATION_OWNER=1v1-edit-arena-security-owner
ROBLOX_OPEN_CLOUD_GROUP_ID=32736689
ROBLOX_ASSET_ALLOWED_CREATOR_IDS=32736689

# Keep production and staging identifiers separate in every report.
ROBLOX_PRODUCTION_UNIVERSE_ID=5112018969
ROBLOX_PRODUCTION_PLACE_ID=14835231599
ROBLOX_STAGING_UNIVERSE_ID=8279974211
ROBLOX_STAGING_PLACE_ID=126501402641505

# Declarative governance constraints. These do not grant Roblox permissions;
# the actual key restrictions in Creator Hub remain authoritative.
ROBLOX_OPEN_CLOUD_ALLOWED_ENVIRONMENTS=staging,production
ROBLOX_OPEN_CLOUD_AUTH_MODE=api-key
ROBLOX_OPEN_CLOUD_ACCESS_MODE=read-only
ROBLOX_OPEN_CLOUD_MUTATIONS_REQUIRE_APPROVAL=true
ROBLOX_OPEN_CLOUD_ALLOW_PRODUCTION_MUTATIONS=false
ROBLOX_OPEN_CLOUD_DRY_RUN=true
ROBLOX_OPEN_CLOUD_IP_RESTRICTION_STATUS=missing
ROBLOX_OPEN_CLOUD_EXPIRATION_STATE=active
ROBLOX_OPEN_CLOUD_LAST_VERIFIED_AT=

# Capability flags are a second local boundary; they never expand the API
# key's Roblox-side permissions. Keep every mutation disabled for the initial
# governance key.
ROBLOX_ENABLE_ASSET_MUTATIONS=false
ROBLOX_ENABLE_COMMERCE_MUTATIONS=false
ROBLOX_ENABLE_PLACE_PUBLISHING=false
ROBLOX_ENABLE_USER_RESTRICTIONS=false
ROBLOX_ENABLE_LUAU_EXECUTION=false
ROBLOX_ENABLE_GROUP_ROLE_MUTATIONS=false
ROBLOX_ENABLE_SPONSORED_CAMPAIGN_MUTATIONS=false

# Local review token for protected Roblox governance MCP tools. Production
# hosting should use the OAuth provider configured for the ChatGPT app instead.
DOOLITTLE_ROBLOX_GOVERNANCE_MCP_BEARER_TOKEN=

# Persistent memory limits for the two long-lived Doolittle stores.
DOOLITTLE_MEMORY_CHAR_LIMIT=2200
DOOLITTLE_USER_CHAR_LIMIT=1375

# Session search behavior.
DOOLITTLE_SESSION_SEARCH_LIMIT=6

# Cron scheduler tick interval in seconds.
DOOLITTLE_CRON_TICK_SECONDS=30

# Optional delivery/file outputs for scheduled runs.
DOOLITTLE_CRON_OUTPUT_DIR=.doolittle/cron-output

# Agentic loop
DOOLITTLE_RUN_DEPTH=standard           # quick | standard | deep | explore
# DOOLITTLE_MAX_ITERATIONS=45          # explicit override (defaults to run depth preset)
DOOLITTLE_TOOL_PROGRESS=new            # off | new | all | verbose
# DOOLITTLE_PERF_TRACE=true            # log per-turn timing spans for live performance debugging

# Optional official Telegram plugin settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ROOT=
TELEGRAM_ALLOWED_CHATS=

# Additional transport settings.
DISCORD_BOT_TOKEN=
# Public guild identifier for the single controlled research server.
# Required only when running the read-only Discord governance collector.
DISCORD_GOVERNANCE_GUILD_ID=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SIGNAL_CLI_COMMAND=
MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
EMAIL_SEND_COMMAND=
FAL_API_KEY=
SMS_SEND_COMMAND=
MATTERMOST_URL=
MATTERMOST_TOKEN=
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=
DINGTALK_WEBHOOK_URL=
DINGTALK_ACCESS_TOKEN=

# Browser automation settings.
# Lightpanda is the default browser backend, with automatic fallback to basic HTTP mode if unavailable.
DOOLITTLE_BROWSER_PROVIDER=lightpanda
DOOLITTLE_BROWSER_COMMAND=lightpanda
DOOLITTLE_BROWSER_CDP_URL=
DOOLITTLE_BROWSER_OBEY_ROBOTS=true

# Execution backend settings. Supported values: local, docker, podman, ssh, singularity, daytona, modal.
DOOLITTLE_EXECUTION_BACKEND=local
DOOLITTLE_EXECUTION_COMMAND_TIMEOUT_MS=30000
DOOLITTLE_EXECUTION_HEALTH_TIMEOUT_MS=5000
DOOLITTLE_CONTAINER_CPU_LIMIT=2
DOOLITTLE_CONTAINER_MEMORY_LIMIT=2g
DOOLITTLE_CONTAINER_PIDS_LIMIT=256
DOOLITTLE_CONTAINER_READ_ONLY_ROOT=true
DOOLITTLE_DOCKER_IMAGE=oven/bun:latest
DOOLITTLE_DOCKER_NETWORK=host
DOOLITTLE_DOCKER_WORKSPACE_PATH=/workspace
DOOLITTLE_DOCKER_ENV_PASSTHROUGH=PATH,HOME,OLLAMA_API_ENDPOINT,OPENAI_API_KEY,ANTHROPIC_API_KEY,DEVIN_MODEL,DEVIN_CLI_COMMAND
DOOLITTLE_SINGULARITY_IMAGE=
DOOLITTLE_DAYTONA_TARGET=
DOOLITTLE_DAYTONA_COMMAND=
DOOLITTLE_DAYTONA_SHELL=/bin/sh
DOOLITTLE_DAYTONA_WORKSPACE_PATH=/workspace
DOOLITTLE_DAYTONA_SNAPSHOT=
DOOLITTLE_DAYTONA_BOOTSTRAP_COMMAND=
DOOLITTLE_DAYTONA_STATUS_COMMAND=
DOOLITTLE_DAYTONA_INSPECT_COMMAND=
DOOLITTLE_MODAL_TARGET=
DOOLITTLE_MODAL_COMMAND=
DOOLITTLE_MODAL_SHELL=/bin/bash
DOOLITTLE_MODAL_WORKSPACE_PATH=/workspace
DOOLITTLE_MODAL_ENVIRONMENT=
DOOLITTLE_MODAL_BOOTSTRAP_COMMAND=
DOOLITTLE_MODAL_STATUS_COMMAND=
DOOLITTLE_MODAL_INSPECT_COMMAND=
DOOLITTLE_REMOTE_SYNC_MODE=mirror
DOOLITTLE_REMOTE_SYNC_INCLUDE=**/*
DOOLITTLE_REMOTE_SYNC_EXCLUDE=.git,.doolittle,node_modules,dist,coverage,.cache,.turbo,.DS_Store
DOOLITTLE_REMOTE_ARTIFACT_PATHS=.doolittle/remote-artifacts,.doolittle/trajectories,.doolittle/cron-output
DOOLITTLE_REMOTE_ARTIFACT_POLICY=metadata-only
DOOLITTLE_REMOTE_WORKSPACE_LABEL=doolittle-workspace
DOOLITTLE_SSH_HOST=
DOOLITTLE_SSH_USER=
DOOLITTLE_SSH_PATH=
DOOLITTLE_SSH_PORT=22
DOOLITTLE_SSH_KEY_PATH=
DOOLITTLE_SSH_STRICT_HOST_KEY_CHECKING=false

# Optional MCP and future production persistence settings.
MCP_SERVER_COMMAND=
MCP_TIMEOUT_MS=10000
ACP_SERVER_COMMAND=
ACP_TIMEOUT_MS=10000
DATABASE_URL=
